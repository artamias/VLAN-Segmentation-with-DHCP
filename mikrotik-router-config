#configuration via GUI

#combine multiple ports into bridge mode
/interface/bridge/add name=bridge-WAN
/interface/bridge/add name=bridge-LAN

#ether 1 wan bridge and ether 2 & ether 3 lan bridge
/interface/bridge/port/add interface=ether1 bridge=bridge-WAN
/interface/bridge/port/add interface=ether2 bridge=bridge-LAN
/interface/bridge/port/add interface=ether3 bridge=bridge-LAN

#add default route wan to isp (dynamic IP)
/ip/dhcp-client/add interface=bridge-WAN use-peer-dns=no add-default-route=yes

#set dns static (google dns)
/ip/dns/set servers=8.8.8.8,8.8.4.4 allow-remote-requests=yes

#set firewall for wan IP
/ip/firewall/nat/add chain=srcnat out-interface=bridge-WAN action=masquerade

#check is bridge-WAN bound
/ip/dhcp-client/print

#add IP Address for VLAN 10 and VLAN 20
/interface/vlan/add name=Vlan10 vlan-id=10 interface=bridge-LAN
/interface/vlan/add name=Vlan20 vlan-id=20 interface=bridge-LAN
/ip/address/add address=192.168.2.1/24 interface=Vlan10
/ip/address/add address=192.168.3.1/24 interface=Vlan20

